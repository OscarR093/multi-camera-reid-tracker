# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Identity TTL in seconds (10 minutes default)
IDENTITY_TTL=600

# Matching thresholds
HSV_MATCH_THRESHOLD=0.7
HEIGHT_MATCH_THRESHOLD=0.15

# Cameras (comma-separated RTSP URLs or video file paths)
# Use the same video twice to test cross-camera identity matching
CAMERA_SOURCES=example/CCTV_example.mp4,example/CCTV_example.mp4

# Detection
DETECTION_CONFIDENCE=0.5
DETECTION_INTERVAL=1

# API
API_HOST=0.0.0.0
API_PORT=8000

# SQLite
SQLITE_DB_PATH=data/persons.db

# Auth
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Virtual camera (development only)
VIDEO_FILE=example/CCTV_example.mp4
RTSP_PORT_START=8554
